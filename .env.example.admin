# Super Admin Environment Variables

# ============================================
# SUPER ADMIN CREDENTIALS
# ============================================
# These are used by the seeding script to create the first super admin user
# Change these values before running the seed script

# Super Admin Email (required)
SUPER_ADMIN_EMAIL=superadmin@gmail.com

# Super Admin Password (required)
# IMPORTANT: Use a strong password with:
# - At least 12 characters
# - Mix of uppercase and lowercase letters
# - Numbers and special characters
# Example: MySecureP@ssw0rd2026!
SUPER_ADMIN_PASSWORD=Superadmin@123

# Super Admin Name (optional, defaults to "Super Admin")
SUPER_ADMIN_NAME=Super Admin

# ============================================
# SECURITY NOTES
# ============================================
# 1. NEVER commit this file with real credentials to version control
# 2. Use different passwords for development, staging, and production
# 3. Change the default password immediately after first login
# 4. Store production credentials in a secure password manager
# 5. Use environment-specific .env files:
#    - .env.development
#    - .env.staging
#    - .env.production
